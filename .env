# memory | file — se ausente ou inválido, usa modo memória (DATABASE_URL_MEMORY ou padrão em tmp)
DB_STORAGE_TYPE=memory

# URL SQLite em memória (modo memory). Deixe vazio para usar o padrão (tmpdir + mode=memory).
DATABASE_URL_MEMORY=

# URL SQLite em arquivo: usada no modo file e pelo Prisma CLI (generate / db push)
DATABASE_URL=file:./dev.db

PORT=3000
CSV_FILE_PATH=./Movielist.csv
